+++ BUILTINS
*** Verifies built-in message behavior for "boolean or" and checks that returned values and side effects match expectations.
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    r1 := true or: [| _ := false. ].
    r2 := false or: [| _ := false. ].
    _ := (r1 asString) print.
    _ := ' ' print.
    _ := (r2 asString) print.
  ]
}
