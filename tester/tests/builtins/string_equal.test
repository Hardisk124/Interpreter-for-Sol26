+++ BUILTINS
*** Verifies built-in message behavior for "string equal" and checks that returned values and side effects match expectations.
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    _ := (('abc' equalTo: 'abc') asString) print.
    _ := ' ' print.
    _ := (('abc' equalTo: 'xyz') asString) print.
  ]
}
