+++ BUILTINS
*** Verifies built-in message behavior for "object identical" and checks that returned values and side effects match expectations.
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    a := Object new.
    b := a.
    c := Object new.
    _ := ((a identicalTo: b) asString) print.
    _ := ' ' print.
    _ := ((a identicalTo: c) asString) print.
  ]
}
