*** Verifies attribute behavior in the scenario "attribute in subclass", including correct assignment, lookup, and returned values.
!C! 0
!I! 0
>>> 1

class Base : Object {
  setup [|
    _ := self data: 99.
  ]
}
class Child : Base {
  run [|
    _ := self setup.
    _ := ((self data) asString) print.
  ]
}
class Main : Object {
  run [|
    c := Child new.
    _ := c run.
  ]
}
