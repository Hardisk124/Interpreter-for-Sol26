+++ EDGECASES
*** Verifies edge-case behavior for "block passed around" to ensure stable and consistent semantics in boundary conditions.
!C! 0
!I! 0
>>> 2

class Box : Object {
  run [|
    _ := (self blk) value.
  ]
}
class Main : Object {
  run [|
    msg := 'late'.
    b := Box new.
    _ := b blk: [| _ := msg print. ].
    msg := 'modified'.
    _ := b run.
  ]
}
