+++ EDGECASES
*** Verifies edge-case behavior for "from copy" to ensure stable and consistent semantics in boundary conditions.
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    a := 5.
    b := Integer from: a.
    _ := ((a equalTo: b) asString) print.
    _ := ' ' print.
    _ := ((a identicalTo: b) asString) print.
  ]
}
