+++ EDGECASES
*** Verifies edge-case behavior for "true false singleton" to ensure stable and consistent semantics in boundary conditions.
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    a := True new.
    b := True new.
    _ := ((a identicalTo: b) asString) print.
    _ := ' ' print.
    _ := ((a identicalTo: true) asString) print.
  ]
}
