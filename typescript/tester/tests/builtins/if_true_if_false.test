+++ BUILTINS
*** Verifies built-in message behavior for "if true if false" and checks that returned values and side effects match expectations.
!C! 0
!I! 0
>>> 2

class Main : Object {
  run [|
    _ := (3 greaterThan: 1)
      ifTrue: [| _ := 'yes' print. ]
      ifFalse: [| _ := 'no' print. ].
    _ := '\n' print.
    _ := (1 greaterThan: 3)
      ifTrue: [| _ := 'yes' print. ]
      ifFalse: [| _ := 'no' print. ].
  ]
}
