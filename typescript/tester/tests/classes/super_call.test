+++ CLASSES
*** Verifies class and method semantics for "super call", including dispatch, inheritance, and method execution behavior.
!C! 0
!I! 0
>>> 1

class A : Object {
  greet [|
    _ := 'A' print.
  ]
}
class B : A {
  greet [|
    _ := super greet.
    _ := 'B' print.
  ]
}
class Main : Object {
  run [|
    b := B new.
    _ := b greet.
  ]
}
