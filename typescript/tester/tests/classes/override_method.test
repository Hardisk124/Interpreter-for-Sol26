+++ CLASSES
*** Verifies class and method semantics for "override method", including dispatch, inheritance, and method execution behavior.
!C! 0
!I! 0
>>> 1

class Animal : Object {
  speak [|
    _ := 'animal' print.
  ]
}
class Dog : Animal {
  speak [|
    _ := 'woof' print.
  ]
}
class Main : Object {
  run [|
    d := Dog new.
    _ := d speak.
  ]
}
